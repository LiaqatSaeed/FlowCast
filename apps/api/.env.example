# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DASHBOARD_URL=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────
# Used automatically when running via Docker Compose
DATABASE_URL=postgresql://flowcast:flowcast_secret@localhost:5432/flowcast

# ─── Auth ────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret_string

# ─── AI & Media APIs ────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
PEXELS_API_KEY=

# ─── Publishing APIs ────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback
META_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
